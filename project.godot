; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Angst N Anchors"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ServerConfig="*res://scripts/network/server_config.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
GameSettings="*res://scripts/state/game_settings.gd"
WorldWeather="*res://scripts/weather/world_weather.gd"
WeatherLighting="*res://scripts/weather/weather_lighting.gd"
WorldClock="*res://scripts/time/world_clock.gd"
ContractRegistry="*res://scripts/cargo/contract_registry.gd"
PlayerSession="*res://scripts/player/player_session.gd"
GameMenu="*res://scripts/ui/game_menu.gd"
GameState="*res://scripts/state/game_state.gd"
DebugHud="*res://scripts/ui/debug_hud.gd"
Telemetry="*res://scripts/state/telemetry.gd"
LocalPlayerView="*res://scripts/state/local_player_view.gd"
Tutorial="*res://scripts/state/tutorial.gd"
AutonomousVesselManager="*res://scripts/player/autonomous_vessel_manager.gd"

