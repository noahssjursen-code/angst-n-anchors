[sub_resource type="Shader" id="Shader_jsaxv"]
code = "shader_type spatial;
render_mode cull_disabled, shadows_disabled;
void fragment() {
	float s = fract((UV.x + UV.y) * 4.0);
	ALBEDO = s > 0.5 ? vec3(0.95, 0.78, 0.0) : vec3(0.06, 0.06, 0.06);
	ROUGHNESS = 0.7;
	METALLIC = 0.05;
}"

